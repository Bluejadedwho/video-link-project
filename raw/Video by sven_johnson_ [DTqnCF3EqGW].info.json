ct_ratio": 0.56, "filesize_approx": 1861906, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-1158261936127453v - 720x1280 (DASH video)"}], "title": "Video by sven_johnson_", "description": "the original rise and grind \n.\n.\n.\n#funny #memes #meme #comedy #relatable", "duration": 16.8, "timestamp": 1768768842, "uploader_id": "1808100939", "uploader": "Sven Johnson", "channel": "sven_johnson_", "like_count": 8098, "comment_count": 62, "comments": [{"author": "saenzheros", "author_id": "64219713352", "id": "18384447073092201", "text": "You‘re fucking hilarious, I appreciate what you do. But your energy might be put to better use reading books, these ancient scribbles that say something I guess, I heard, don’t know. I‘m not one to gossip though.", "timestamp": 1774796237}, {"author": "omegasett", "author_id": "5843528679", "id": "18070037243209423", "text": "Babies first pyramid scheme", "timestamp": 1772541973}, {"author": "_toocomplexforyourlabels_", "author_id": "242292377", "id": "18080116763365707", "text": "😂", "timestamp": 1772029570}, {"author": "evann_patrickk", "author_id": "4731504", "id": "17875470027531506", "text": "Magazine drive was the only top notch one. Kid at my school earned the gas powered Go Kart. I swear they miscalculated on what it took to earn the prizes that year because half the class was earning shit left and right. They gave out a decent bit of cash too. Still can’t believe they got away with playing Nelly for the assembly but that dude killed it. Best assembly ever.", "timestamp": 1771878391}, {"author": "nh_isnt_real603", "author_id": "178671812", "id": "18562472212000939", "text": "I once went door to door selling magazines and I was gone so long my mom called the cops because she thought I had been kidnapped.", "timestamp": 1771798818}, {"author": "thebulldoghenry", "author_id": "2128278778", "id": "18089867336118440", "text": "😂😂😂😂", "timestamp": 1771530974}, {"author": "taliaceravolo", "author_id": "288961703", "id": "17871241308447664", "text": "Or the “unlimited ice cream party” they promised", "timestamp": 1771525927}], "thumbnails": [{"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.71878-15/618980476_1425251175855049_3565657357972629343_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDB4MTEzNi5zZHIuZjcxODc4Lm5mcmFtZV9jb3Zlcl9mcmFtZS5jMiJ9&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_cat=101&_nc_oc=Q6cZ2gGR82JoEyuq-yUj3cxrHL31DB-n3TMM4zBkZZhOA49IldAE2BM5IR2opBZbGk7E6qM&_nc_ohc=G1nh6cfJB-IQ7kNvwGnmYCq&_nc_gid=U4lS2M-0nweomZj6mH_HIA&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af1eDwdNBKDHqpECjEI7cZ1d6ML62UzOOgU9vq3H4PKQSQ&oe=69D4CE49&_nc_sid=d885a2", "width": 640, "height": 1136, "id": "0", "resolution": "640x1136"}, {"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.71878-15/618980476_1425251175855049_3565657357972629343_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDB4MTEzNi5zZHIuZjcxODc4Lm5mcmFtZV9jb3Zlcl9mcmFtZS5jMiJ9&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_cat=101&_nc_oc=Q6cZ2gGR82JoEyuq-yUj3cxrHL31DB-n3TMM4zBkZZhOA49IldAE2BM5IR2opBZbGk7E6qM&_nc_ohc=G1nh6cfJB-IQ7kNvwGnmYCq&_nc_gid=U4lS2M-0nweomZj6mH_HIA&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af1eDwdNBKDHqpECjEI7cZ1d6ML62UzOOgU9vq3H4PKQSQ&oe=69D4CE49&_nc_sid=d885a2", "width": 750, "height": 1331, "id": "1", "resolution": "750x1331"}, {"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.71878-15/618980476_1425251175855049_3565657357972629343_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDB4MTEzNi5zZHIuZjcxODc4Lm5mcmFtZV9jb3Zlcl9mcmFtZS5jMiJ9&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_cat=101&_nc_oc=Q6cZ2gGR82JoEyuq-yUj3cxrHL31DB-n3TMM4zBkZZhOA49IldAE2BM5IR2opBZbGk7E6qM&_nc_o