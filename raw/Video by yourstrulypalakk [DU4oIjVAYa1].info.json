iods": true, "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 1341.412, "resolution": "720x1280", "aspect_ratio": 0.56, "filesize_approx": 9324657, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-1266210822078233v - 720x1280 (DASH video)"}], "title": "Video by yourstrulypalakk", "description": "yay", "duration": 55.611, "timestamp": 1771299300, "uploader_id": "75997085380", "uploader": "palak", "channel": "yourstrulypalakk", "like_count": 1272, "comment_count": 11, "comments": [{"author": "rajeshkumaralh2", "author_id": "80682720840", "id": "18096126683062044", "text": "The Best message ever... thanks.", "timestamp": 1774373450}, {"author": "anand_mashetty1988", "author_id": "78397160186", "id": "18118804288612320", "text": "🔥", "timestamp": 1773244331}, {"author": "jawbreaker2723", "author_id": "53578180957", "id": "17947949532103243", "text": "It's getting tough to understand", "timestamp": 1772427642}, {"author": "syedsaad2600", "author_id": "59662799230", "id": "17940492698998109", "text": "I feel like my life is full of chasing validation partly because I received female validation from one of my close friends very early in my life. I haven't learnt to delay gratification and work sustainably during tough times when I don't have much support.", "timestamp": 1772282821}, {"author": "mr.datta_chowdhary01", "author_id": "3953842753", "id": "18092994083000914", "text": "Jung was Right", "timestamp": 1771390275}, {"author": "parvvv_1984", "author_id": "74007043019", "id": "18081373388200007", "text": "So trueee and validation is so powerful when it comes from within", "timestamp": 1771309926}, {"author": "irokonran_", "author_id": "66075363268", "id": "18095471767987106", "text": "Most of the control freak people, who only believes in randomnesss don't understand that everything is a cause and effect! Nagarjuna said that if something change occurs then there's an cause, thar cause effect your next move! Same for every people!", "timestamp": 1771305987}, {"author": "_charygaru", "author_id": "41346413959", "id": "18362391106163048", "text": "😮😮", "timestamp": 1771301420}, {"author": "mk_ramana24", "author_id": "47002628976", "id": "18307167754283541", "text": "Can you recommend some books 📚 which will help us to become a more better version of ourselves. I'm a bookworm always reading self help and psychology philosophy related stuff . I like how you express your thoughts 💭 🤔 .", "timestamp": 1771299718}], "thumbnails": [{"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.71878-15/626707511_3943346009297069_6779238574454625115_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDB4MTEzNi5zZHIuZjcxODc4LmRlZmF1bHRfY292ZXJfZnJhbWUuYzIifQ&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_cat=105&_nc_oc=Q6cZ2gHE2z0iqWW1_DOXOQyRq8yWvTu6hqi1EoLqpmzk81cLsFceEKJIojCW19PB3VFLh3Y&_nc_ohc=kRNmPPsDjrsQ7kNvwEGVQbd&_nc_gid=9jKElTX3w-qjMX3-4u8TJA&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af2EITQbG8OivDoEtuYYSTQX-S2VubJty9KpnNoo43LSAw&oe=69D4AE06&_nc_sid=d885a2", "width": 640, "height": 1136, "id": "0", "resolution": "640x1136"}, {"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.71878-15/626707511_3943346009297069_6779238574454625115_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDB4MTEzNi5zZHIuZjcxODc4LmRlZmF1bHRfY292ZXJfZnJhbWUuYzIifQ&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_cat=105&_nc_oc=Q6cZ2gHE2z0iqWW1_DOXOQyRq8yWvTu6hqi1EoLqpmzk81cLsFceEKJIojCW19PB3VFLh3Y&_nc_ohc=kRNmPPsDjrsQ7kNvwEGVQbd&_nc_gid=9jKElTX3w-qjMX3-4u8TJA&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af2EITQbG8OivDoEtuYYSTQX-S2VubJty9KpnNoo43LSAw&oe=69D4AE06&_nc_sid=d885a2", "width": 750, "height": 1331, "id": "1", "resolution": 