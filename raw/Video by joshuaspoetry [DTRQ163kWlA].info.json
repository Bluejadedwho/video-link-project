-1427888038922319v", "ext": "mp4", "width": 1080, "height": 1920, "tbr": 1596.641, "format_note": "DASH video", "container": "mp4_dash", "vcodec": "vp09.00.40.08.00.01.01.01.00", "acodec": "none", "dynamic_range": "SDR", "url": "https://scontent-yyz1-1.cdninstagram.com/o1/v/t2/f2/m367/AQOBKpty4_-GQrfWHTnoFeStFzDmK9S4KMUU9PqPYqGN0potPS9-7QwoH72BB-1XwLBwTCDhUnkfropBDP5Kd3zUDh5LZKbkpNmDunA.mp4?_nc_cat=102&_nc_sid=9ca052&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_ohc=rcumXg7yBm4Q7kNvwHOFJgb&&ccb=17-1&_nc_gid=ntPpoFFg3T0SvODEAM2o1A&_nc_zt=28&_nc_ss=7a32e&oh=00_Af1Rkd1t_xKwBNh-aHWYmQzbmuhme86hqyg5fhz-PqX9uw&oe=69D4BF97", "manifest_stream_number": 0, "is_dash_periods": true, "protocol": "https", "video_ext": "mp4", "audio_ext": "none", "abr": 0, "vbr": 1596.641, "resolution": "1080x1920", "aspect_ratio": 0.56, "filesize_approx": 7956660, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-1427888038922319v - 1080x1920 (DASH video)"}], "title": "Video by joshuaspoetry", "description": "Does all pain have meaning?", "duration": 39.867, "timestamp": 1767918382, "uploader_id": "65324209519", "uploader": "Joshua De Schutter", "channel": "joshuaspoetry", "like_count": 27553, "comment_count": 575, "comments": [{"author": "lileileenandbofus", "author_id": "40759725599", "id": "17876010843436457", "text": "❤️❤️❤️", "timestamp": 1775096255}, {"author": "liz.ker.9", "author_id": "47720309511", "id": "17941832244174165", "text": "You are talent beyond talent👏👏👏", "timestamp": 1774906234}, {"author": "misschadbourne", "author_id": "6694579130", "id": "18111701410703708", "text": "It doesn’t mean anything til u make it mean something", "timestamp": 1774876011}, {"author": "demented_damsel_in_a_dress", "author_id": "10581247959", "id": "18117912673628939", "text": "Thank you !", "timestamp": 1774831771}, {"author": "thatpennerguy", "author_id": "4106622695", "id": "18058942280650816", "text": "I feel this now, deep down.  I’ve live with bipolar disorder for 17 years.  2 hospitalizations, multiple mental breakdowns, 1 fractured skull and half a body paralyzed later, and it’s only getting harder to deal with.  On top of that, 6 months ago I started developing a lung issue that looks like it could be COPD.  I’m only 36.  Why?  For what?", "timestamp": 1774763285}, {"author": "shanagafitness", "author_id": "6963848691", "id": "18096878903044299", "text": "Life throws that lemon to me that doesn't make lemonade a few time and it hurts", "timestamp": 1774759782}, {"author": "home.blessed.home", "author_id": "9721584875", "id": "17945566071139278", "text": "Mic drop! I love your Flow ✨️", "timestamp": 1774756542}, {"author": "robaire8670", "author_id": "4670561195", "id": "18073922429202022", "text": "Enjoy your brilliant work", "timestamp": 1774607021}, {"author": "robaire8670", "author_id": "4670561195", "id": "18569210620050225", "text": "Feelings are healing", "timestamp": 1774606898}, {"author": "ericsvizeny", "author_id": "7271222", "id": "18103139353925642", "text": "", "timestamp": 1774592889}], "thumbnails": [{"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.71878-15/612064080_1183027427368471_3918099602493777532_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDB4MTEzNi5zZHIuZjcxODc4Lm5mcmFtZV9jb3Zlcl9mcmFtZS5jMiJ9&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_cat=107&_nc_oc=Q6cZ2gHm7sxIjYUwTlMsbgEuRXNNP9qAa-RN3OFEDIYRafZZe4caQk88B5KudUtey2r_duk&_nc_ohc=20p-TdfMhX0Q7kNvwEq2OfT&_nc_gid=ntPpoFFg3T0SvODEAM2o1A&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af34Rp4Tb2Rq0vciOp50XN6qNAHHPG88PRNJETqBqDv8GA&oe=69D4AF05&_nc_sid=d885a2", "width": 640, "height": 1136, "id": "0", "resolution": "640x1136"}, {"url": "https://scontent-yyz1-1.cdninstagram.com/