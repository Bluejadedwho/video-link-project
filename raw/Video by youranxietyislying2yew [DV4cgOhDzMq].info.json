": 0, "vbr": 2371.044, "resolution": "1080x1920", "aspect_ratio": 0.56, "filesize_approx": 44941064, "http_headers": {"User-Agent": "Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) Chrome/143.0.0.0 Safari/537.36", "Accept": "text/html,application/xhtml+xml,application/xml;q=0.9,*/*;q=0.8", "Accept-Language": "en-us,en;q=0.5", "Sec-Fetch-Mode": "navigate", "Referer": "https://www.instagram.com/"}, "format": "dash-1650593925935428v - 1080x1920 (DASH video)"}], "title": "Video by youranxietyislying2yew", "description": "Can I talk to your inner child?", "duration": 151.633, "timestamp": 1773528000, "uploader_id": "48593623545", "uploader": "Ryan Primer", "channel": "youranxietyislying2yew", "like_count": 121456, "comment_count": 6328, "comments": [{"author": "anja83181905", "author_id": "44909448944", "id": "18572531503036237", "text": "❤️", "timestamp": 1775171018}, {"author": "beautifuly_unfinished", "author_id": "534328792", "id": "18090235030933888", "text": "How can I play this on repeat for her? x", "timestamp": 1775170891}, {"author": "beautifuly_unfinished", "author_id": "534328792", "id": "17868352359607843", "text": "I wish I could explain the feeling and visualisation from beginning to end - all I know is she needed this x", "timestamp": 1775170770}, {"author": "diana.brosiu.urban.mystic", "author_id": "52385166275", "id": "18070603832275682", "text": "Thank you. Just thank you man. Needed that. ❤️", "timestamp": 1775170692}, {"author": "_kaiaah_", "author_id": "5478595585", "id": "18047632316552200", "text": "Not ready for this rn... Pls like this so I come back", "timestamp": 1775169723}, {"author": "morsan57", "author_id": "275166112", "id": "18097310483013313", "text": "Thank you 💙 your words hit home. Much needed thruth -for this grown-up kid of 68 yrs", "timestamp": 1775169348}, {"author": "ella_maria1104", "author_id": "1723814278", "id": "18071775326646285", "text": "We cried a lot, and we needed that", "timestamp": 1775168812}, {"author": "unscripted_stitches", "author_id": "73346401759", "id": "18434971897186557", "text": "There is so much pain in your eyes...😢😭 I pray you are okay 🙏", "timestamp": 1775166367}, {"author": "jennaroseb3", "author_id": "274251521", "id": "18102221599745918", "text": "By the way, im not sure what your career is but I think you'd be outstanding in social work field. We need more people like you. Thank you for being you my friend 🧡", "timestamp": 1775165385}], "thumbnails": [{"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.71878-15/652387177_26245791691719020_6977981402082447792_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDB4MTEzNi5zZHIuZjcxODc4LmRlZmF1bHRfY292ZXJfZnJhbWUuYzIifQ&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_cat=108&_nc_oc=Q6cZ2gFnJKO-yPEmIDCSRmQqAjI5SPKbqB7Yk9M5DNl05UXePtE7pChe31EcSQ_y1L4oXcE&_nc_ohc=3sDG-jLPZl8Q7kNvwFZQQMo&_nc_gid=juVlGP6gDyWuzLdW4IU0CQ&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af1ITLPeTAsKVnjRpYbMhy-3Xh2xv8ytlN7jtm6tS9QL_Q&oe=69D4B0AD&_nc_sid=d885a2", "width": 640, "height": 1136, "id": "0", "resolution": "640x1136"}, {"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.71878-15/652387177_26245791691719020_6977981402082447792_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDB4MTEzNi5zZHIuZjcxODc4LmRlZmF1bHRfY292ZXJfZnJhbWUuYzIifQ&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_cat=108&_nc_oc=Q6cZ2gFnJKO-yPEmIDCSRmQqAjI5SPKbqB7Yk9M5DNl05UXePtE7pChe31EcSQ_y1L4oXcE&_nc_ohc=3sDG-jLPZl8Q7kNvwFZQQMo&_nc_gid=juVlGP6gDyWuzLdW4IU0CQ&edm=ANTKIIoBAAAA&ccb=7-5&oh=00_Af1ITLPeTAsKVnjRpYbMhy-3Xh2xv8ytlN7jtm6tS9QL_Q&oe=69D4B0AD&_nc_sid=d885a2", "width": 750, "height": 1331, "id": "1", "resolution": "750x1331"}, {"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.71878-15/652387177_26245791691719020_6977981402082447792_n.jpg?stp=dst-jpg_e15_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi42NDB4MTEzNi5zZHIuZjcxODc4LmRlZmF1bHRfY292ZXJfZnJhbWUuYzIifQ&_nc_ht=scontent-yyz1-1.cdninstagram.com