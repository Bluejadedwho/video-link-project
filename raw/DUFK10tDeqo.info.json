: 1775353102}, {"author": "anton37427", "author_id": "2122529303", "id": "17919027702320888", "text": "😢", "timestamp": 1775342462}, {"author": "trx.flipz", "author_id": "53405377671", "id": "18060347786408535", "text": "Have you ever been a cutter? Relapsing suuuucks worse than drugs. I’ve been addicted to everything under the sun. Natural, not natural. Do your own insights but yeah dude self healing is hard.", "timestamp": 1775335768}, {"author": "sunnybby.__", "author_id": "11120468789", "id": "18191570488318653", "text": "Now it’s a aching bone in the weather no one else can feel", "timestamp": 1775299466}, {"author": "sunnybby.__", "author_id": "11120468789", "id": "18094607188869854", "text": "🔥", "timestamp": 1775273971}, {"author": "mikeg0324", "author_id": "2159471514", "id": "18020762108652023", "text": "Wooh. That spoke directly to my soul. Keep writing girl. That was deep. Beautiful.", "timestamp": 1775261282}, {"author": "alliejean_2025", "author_id": "65445638575", "id": "18059160590451053", "text": "“Sometimes I miss being broken, because at least broken things get to be held”", "timestamp": 1775247486}, {"author": "gormlyiii", "author_id": "21565949939", "id": "18082910873613737", "text": "I sees in your eyes. It's okay", "timestamp": 1775209605}, {"author": "juscallmetia", "author_id": "193795996", "id": "17863431798670251", "text": "my god. 💔", "timestamp": 1775192281}, {"author": "gtopp87", "author_id": "44258757340", "id": "17881944627523751", "text": "Beautiful words. You gained another follow", "timestamp": 1775181424}], "thumbnails": [{"url": "https://scontent-yyz1-1.cdninstagram.com/v/t51.82787-15/628363909_17941805214114916_8770139578489110016_n.jpg?stp=dst-jpg_e35_p640x640_sh0.08_tt6&efg=eyJ2ZW5jb2RlX3RhZyI6ImltYWdlX3VybGdlbi4yMjY4eDQwMzIuc2RyLmY4Mjc4Ny5kZWZhdWx0X2NvdmVyX2ZyYW1lLmMyIn0&_nc_ht=scontent-yyz1-1.cdninstagram.com&_nc_cat=104&_nc_oc=Q6cZ2gFrNx6Mcumv3-o-5h895FtpcSPkEdH6A1G4GlBn9DqbsrxPthKMYQA_vdgfeI1FU84&_nc_ohc=7D1YFan6z2YQ7kNvwE